    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "chalk": "5.6.2",
    "dotenv": "17.4.2",
    "graphql": "16.14.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "7.2.0",
    "@graphql-codegen/typescript": "6.1.0",
