{
  "include": ["."],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./.generated/*"]
    },

    "moduleResolution": "bundler",
    "target": "esnext",
    "lib": ["esnext"],
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "dist",
    "jsx": "preserve",
    "noEmit": true
  }
}
